{
  "name": "@ody/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 8787",
    "gen:openapi": "tsx src/scripts/generate-openapi.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/services/menu-service.test.ts src/services/customer-service.test.ts src/services/order-service.test.ts"
  },
  "dependencies": {
    "@hono/zod-openapi": "latest",
    "@neondatabase/serverless": "latest",
    "drizzle-orm": "latest",
    "drizzle-zod": "latest",
    "hono": "latest",
    "jose": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260608.1",
    "@types/node": "^25.9.2",
    "dotenv": "latest",
    "drizzle-kit": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
